# Project-01 — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# ── AI providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Model assignments ─────────────────────────────────────────────────────────
# Set the model ID for each agent role.
FUNDAMENTAL_ANALYST_MODEL=
WORLD_RESEARCHER_MODEL=
MANAGER_MODEL=

# ── Market data ───────────────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ── Notifications ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=

# ── Prompts ───────────────────────────────────────────────────────────────────
# Path to directory containing agent prompt files.
# Prompts are not included in this repository.
PROMPT_DIR=/path/to/your/prompt-files

# ── Budget controls ───────────────────────────────────────────────────────────
MAX_COST_PER_REPORT_USD=0.75
DAILY_BUDGET_LIMIT_USD=10.00

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
PORT=8501
